@{
    ViewData["Title"] = "Add New Puppy";
}

<div class="container py-5">

    <form asp-controller="Admin"
          asp-action="AddPuppy"
          method="post">

        <div class="row g-5">

            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <label><strong>Profile Picture URL</strong></label>
                        <input type="text" name="profile_pic" class="form-control" />
                    </div>
                </div>
            </div>

            <div class="col-md-6 d-flex flex-column">

                <div class="mb-3">
                    <label><strong>Name</strong></label>
                    <input type="text" name="name" class="form-control form-control-lg" />
                </div>

                <div class="mb-4">
                    <label><strong>Price ($)</strong></label>
                    <input type="number" name="fee" class="form-control" step="0.01" />
                </div>

                <div class="mb-3">
                    <label><strong>Breed</strong></label>
                    <input type="text" name="breed" class="form-control" />
                </div>

                <div class="mb-3">
                    <label><strong>Sex</strong></label>
                    <input type="text" name="sex" class="form-control" />
                </div>

                <div class="mb-3">
                    <label><strong>Age</strong></label>
                    <input type="text" name="age" class="form-control" />
                </div>

                <div class="mb-4">
                    <label><strong>Description</strong></label>
                    <textarea name="description" class="form-control" rows="4"></textarea>
                </div>

                <div class="mt-auto">

                    <button type="submit"
                            class="btn btn-primary btn-lg w-100 mb-2">
                        Add
                    </button>

                    <a asp-controller="Admin"
                       asp-action="AlterDB"
                       class="btn btn-outline-secondary w-100">
                        ← Back to Catalog
                    </a>

                </div>

            </div>
        </div>

    </form>

</div>