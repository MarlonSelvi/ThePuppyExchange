@model IEnumerable<DataAccessLayer.Entities.PuppyModel>

@{
    ViewData["Title"] = "Puppy Catalog";
}

<div class="container">
    <h1 class="mb-4">Puppy Catalog</h1>

    <div class="row">
        @foreach (var puppy in Model)
        {
            <div class="col-12 col-sm-6 col-md-4 col-lg-3 mb-3">

                <div class="card h-100 shadow-sm puppy-card" style="font-size: 0.9rem;">

                    <img src="@puppy.profile_pic"
                            class="card-img-top img-fluid"
                            alt="@puppy.name"
                            style="height: 200px; object-fit: cover;" />

                    <div class="card-body d-flex flex-column p-2">

                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h5 class="card-title mb-0">@puppy.name</h5>
                            <span class="fw-bold text-success">$@puppy.fee</span>
                        </div>

                        <p class="mb-1"><strong>Breed:</strong> @puppy.breed</p>

                        <div class="mt-auto d-flex justify-content-end">
                               
                        </div>
                    </div>
                    <a type="submit"
                        class="btn btn-sm"
                        style="background-color: #d4a017; color: #fff; border: none;" asp-controller="Admin" asp-action="EditPuppy" asp-route-id="@puppy.product_id">
                        Edit
                    </a>
                </div>

            </div>
        }
        <a type="submit"
           class="btn btn-lg"
           style="background-color: #d4a017; color: #fff; border: none;" asp-controller="Admin" asp-action="AddPuppy">
            Add New Puppy
        </a>
    </div>
</div>